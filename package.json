{
  "name": "prompt-toolkit",
  "private": true,
  "version": "0.1.0",
  "description": "Prompt Toolkit desktop app workspace",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm --filter @prompt-toolkit/desktop dev",
    "build": "pnpm --filter @prompt-toolkit/desktop build",
    "tauri:dev": "pnpm --filter @prompt-toolkit/desktop tauri:dev",
    "tauri:build": "pnpm --filter @prompt-toolkit/desktop tauri:build",
    "lint": "pnpm --filter @prompt-toolkit/desktop lint",
    "test": "pnpm --filter @prompt-toolkit/desktop test"
  }
}
